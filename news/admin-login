<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - Khabar Darjeeling Ko</title>
    <meta name="robots" content="noindex, nofollow">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 100%);
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        .login-container {
            background: #181818;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            padding: 40px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        .logo {
            text-align: center;
            margin-bottom: 30px;
            font-size: 40px;
        }

        h1 {
            text-align: center;
            margin-bottom: 10px;
            font-size: 24px;
        }

        .subtitle {
            text-align: center;
            color: #888;
            margin-bottom: 30px;
            font-size: 14px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #ddd;
            font-weight: bold;
            font-size: 13px;
        }

        input {
            width: 100%;
            padding: 12px;
            background: #0f0f0f;
            border: 1px solid #333;
            border-radius: 6px;
            color: #ffffff;
            font-size: 14px;
            transition: all 0.3s;
        }

        input:focus {
            outline: none;
            border-color: #c0392b;
            box-shadow: 0 0 8px rgba(192, 57, 43, 0.2);
            background: #1a1a1a;
        }

        input::placeholder {
            color: #666;
        }

        .login-btn {
            width: 100%;
            padding: 12px;
            background: #c0392b;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 10px;
        }

        .login-btn:hover:not(:disabled) {
            background: #a02e1f;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(192, 57, 43, 0.3);
        }

        .login-btn:disabled {
            background: #666;
            cursor: not-allowed;
            opacity: 0.6;
        }

        .message {
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 20px;
            display: none;
            border-left: 4px solid;
            font-size: 13px;
        }

        .error-message {
            background: #3d1514;
            color: #ff6b57;
            border-left-color: #c0392b;
            display: block;
        }

        .success-message {
            background: #1a3a1a;
            color: #6bff57;
            border-left-color: #28a745;
            display: block;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
            font-size: 13px;
        }

        .remember-me input {
            width: auto;
            cursor: pointer;
        }

        .forgot-password {
            text-align: right;
            margin-bottom: 20px;
        }

        .forgot-password a {
            color: #ff6b57;
            text-decoration: none;
            font-size: 12px;
            transition: color 0.3s;
        }

        .forgot-password a:hover {
            color: #ffffff;
        }

        .divider {
            border: none;
            border-top: 1px solid #333;
            margin: 25px 0;
        }

        .info-box {
            background: #0f0f0f;
            border-left: 3px solid #c0392b;
            padding: 15px;
            border-radius: 4px;
            font-size: 12px;
            color: #888;
            margin-top: 20px;
        }

        .info-box strong {
            color: #ddd;
        }

        .spinner {
            display: inline-block;
            width: 14px;
            height: 14px;
            border: 2px solid #333;
            border-top-color: #c0392b;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin-right: 8px;
            vertical-align: middle;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        @media (max-width: 480px) {
            .login-container {
                padding: 30px 20px;
            }

            h1 {
                font-size: 20px;
            }

            .logo {
                font-size: 35px;
            }
        }
    </style>
</head>
<body>

<div class="login-container">
    <div class="logo">🏔️</div>
    <h1>Admin Access</h1>
    <p class="subtitle">Khabar Darjeeling Ko</p>

    <div id="messageContainer"></div>

    <form id="loginForm" onsubmit="handleLogin(event)">
        <div class="form-group">
            <label for="email">Email Address</label>
            <input 
                type="email" 
                id="email" 
                name="email"
                placeholder="admin@adharlimbu.online"
                required
                autocomplete="email"
            >
        </div>

        <div class="form-group">
            <label for="password">Password</label>
            <input 
                type="password" 
                id="password" 
                name="password"
                placeholder="Enter password"
                required
                autocomplete="current-password"
            >
        </div>

        <div class="remember-me">
            <input type="checkbox" id="remember" name="remember">
            <label for="remember" style="margin: 0; font-weight: normal;">Remember me</label>
        </div>

        <div class="forgot-password">
            <a href="#" onclick="alert('Contact admin to reset password'); return false;">Forgot password?</a>
        </div>

        <button type="submit" class="login-btn" id="loginBtn">Sign In</button>
    </form>

    <hr class="divider">

    <div class="info-box">
        <strong>⚠️ Security Notice:</strong><br>
        This is a restricted admin area. Unauthorized access is prohibited. All activity is logged.
    </div>
</div>

<script>
// Simple authentication system
// In production, implement proper JWT-based authentication with Supabase Auth

const ADMIN_CREDENTIALS = {
    email: 'admin@adharlimbu.online',
    password: 'khabar@123' // Change this to a strong password!
};

function handleLogin(event) {
    event.preventDefault();

    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value;
    const loginBtn = document.getElementById('loginBtn');
    const messageContainer = document.getElementById('messageContainer');

    // Clear previous messages
    messageContainer.innerHTML = '';

    // Validate
    if (!email || !password) {
        showMessage('Please fill in all fields', 'error');
        return;
    }

    // Show loading state
    loginBtn.disabled = true;
    loginBtn.innerHTML = '<span class="spinner"></span>Signing in...';

    // Simulate authentication delay
    setTimeout(() => {
        if (email === ADMIN_CREDENTIALS.email && password === ADMIN_CREDENTIALS.password) {
            // Login successful
            localStorage.setItem('adminEmail', email);
            localStorage.setItem('adminLoginTime', new Date().toISOString());
            
            if (document.getElementById('remember').checked) {
                localStorage.setItem('rememberAdmin', 'true');
            }

            showMessage('✅ Login successful! Redirecting...', 'success');
            setTimeout(() => {
                window.location.href = '/admin/dashboard.html';
            }, 1500);
        } else {
            // Login failed
            showMessage('❌ Invalid email or password', 'error');
            loginBtn.disabled = false;
            loginBtn.innerHTML = 'Sign In';
            document.getElementById('password').value = '';
            document.getElementById('password').focus();
        }
    }, 500);
}

function showMessage(message, type) {
    const container = document.getElementById('messageContainer');
    container.innerHTML = `<div class="message ${type}-message">${message}</div>`;
}

// Check if already logged in
document.addEventListener('DOMContentLoaded', () => {
    const adminEmail = localStorage.getItem('adminEmail');
    if (adminEmail) {
        window.location.href = '/admin/dashboard.html';
    }

    // Auto-fill if remembered
    if (localStorage.getItem('rememberAdmin') === 'true' && adminEmail) {
        document.getElementById('email').value = adminEmail;
        document.getElementById('remember').checked = true;
    }
});
</script>

</body>
</html>
