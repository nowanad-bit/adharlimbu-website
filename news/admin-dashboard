<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Khabar Darjeeling Ko</title>
    <meta name="robots" content="noindex, nofollow">
    <meta name="theme-color" content="#c0392b">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #0f0f0f;
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
        }

        .dashboard {
            display: grid;
            grid-template-columns: 250px 1fr;
            min-height: 100vh;
        }

        .sidebar {
            background: #111111;
            border-right: 1px solid #2a2a2a;
            padding: 20px;
            position: fixed;
            width: 250px;
            height: 100vh;
            overflow-y: auto;
        }

        .sidebar-logo {
            font-size: 20px;
            font-weight: bold;
            margin-bottom: 30px;
            padding: 15px;
            background: #1a1a1a;
            border-radius: 8px;
            text-align: center;
        }

        .sidebar-menu {
            list-style: none;
        }

        .sidebar-menu li {
            margin-bottom: 10px;
        }

        .sidebar-menu a {
            display: block;
            padding: 12px 15px;
            color: #aaa;
            text-decoration: none;
            border-radius: 6px;
            transition: all 0.3s;
            cursor: pointer;
        }

        .sidebar-menu a:hover,
        .sidebar-menu a.active {
            background: #c0392b;
            color: #ffffff;
        }

        .main-content {
            margin-left: 250px;
            padding: 20px;
        }

        .header {
            background: #181818;
            border-bottom: 1px solid #2a2a2a;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header h1 {
            font-size: 28px;
        }

        .logout-btn {
            background: #c0392b;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .logout-btn:hover {
            background: #a02e1f;
        }

        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 1px solid #2a2a2a;
        }

        .tab-btn {
            padding: 12px 20px;
            background: #1a1a1a;
            border: none;
            color: #aaa;
            cursor: pointer;
            border-bottom: 3px solid transparent;
            transition: all 0.3s;
            font-size: 14px;
            font-weight: bold;
        }

        .tab-btn:hover {
            color: #ddd;
        }

        .tab-btn.active {
            color: #c0392b;
            border-bottom-color: #c0392b;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: #181818;
            padding: 20px;
            border-radius: 8px;
            border: 1px solid #2a2a2a;
            text-align: center;
        }

        .stat-number {
            font-size: 32px;
            font-weight: bold;
            color: #c0392b;
            margin-bottom: 10px;
        }

        .stat-label {
            color: #888;
            font-size: 14px;
        }

        .submission-item {
            background: #181818;
            border: 1px solid #2a2a2a;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 20px;
            align-items: start;
        }

        .submission-details h3 {
            margin-bottom: 8px;
            color: #ffffff;
        }

        .submission-meta {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            font-size: 13px;
            color: #888;
            margin-top: 10px;
        }

        .submission-content {
            color: #aaa;
            font-size: 14px;
            margin-top: 10px;
            max-height: 100px;
            overflow-y: auto;
        }

        .submission-actions {
            display: flex;
            gap: 10px;
            flex-direction: column;
            white-space: nowrap;
        }

        .btn {
            padding: 10px 15px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            font-weight: bold;
            transition: all 0.3s;
            white-space: nowrap;
        }

        .btn-primary {
            background: #c0392b;
            color: white;
        }

        .btn-primary:hover {
            background: #a02e1f;
        }

        .btn-secondary {
            background: #2a2a2a;
            color: #aaa;
            border: 1px solid #333;
        }

        .btn-secondary:hover {
            background: #333;
            color: #ddd;
        }

        .btn-danger {
            background: #8b3a3a;
            color: white;
        }

        .btn-danger:hover {
            background: #6b2a2a;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: #181818;
            border: 1px solid #2a2a2a;
            border-radius: 8px;
            padding: 30px;
            max-width: 600px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .modal-header h2 {
            margin: 0;
        }

        .close-modal {
            background: none;
            border: none;
            color: #aaa;
            font-size: 24px;
            cursor: pointer;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            color: #ddd;
            font-weight: bold;
            font-size: 13px;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 10px;
            background: #0f0f0f;
            border: 1px solid #333;
            border-radius: 6px;
            color: #ffffff;
            font-size: 13px;
            font-family: inherit;
        }

        .form-group textarea {
            min-height: 150px;
            resize: vertical;
        }

        .message {
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 20px;
            display: none;
            border-left: 4px solid;
        }

        .success-message {
            background: #1a3a1a;
            color: #6bff57;
            border-left-color: #28a745;
            display: block;
        }

        .error-message {
            background: #3d1514;
            color: #ff6b57;
            border-left-color: #c0392b;
            display: block;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #666;
        }

        .loading {
            text-align: center;
            padding: 40px;
            color: #666;
        }

        .spinner {
            display: inline-block;
            width: 30px;
            height: 30px;
            border: 3px solid #333;
            border-top-color: #c0392b;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin-right: 10px;
            vertical-align: middle;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .badge-pending {
            background: #8b6b3a;
            color: #ffd966;
        }

        .badge-published {
            background: #3a6b3a;
            color: #6bff57;
        }

        .badge-rejected {
            background: #6b3a3a;
            color: #ff6b57;
        }

        @media (max-width: 768px) {
            .dashboard {
                grid-template-columns: 1fr;
            }

            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                border-right: none;
                border-bottom: 1px solid #2a2a2a;
            }

            .main-content {
                margin-left: 0;
            }

            .submission-item {
                grid-template-columns: 1fr;
            }

            .submission-actions {
                flex-direction: row;
            }

            .header {
                flex-direction: column;
                gap: 15px;
            }

            .tabs {
                flex-wrap: wrap;
            }
        }
    </style>
</head>
<body>

<div class="dashboard">
    <div class="sidebar">
        <div class="sidebar-logo">🏔️ Admin</div>
        <ul class="sidebar-menu">
            <li><a class="tab-btn active" onclick="switchTab('dashboard')">📊 Dashboard</a></li>
            <li><a class="tab-btn" onclick="switchTab('submissions')">📬 Submissions</a></li>
            <li><a class="tab-btn" onclick="switchTab('published')">📰 Published</a></li>
            <li><a class="tab-btn" onclick="switchTab('settings')">⚙️ Settings</a></li>
            <li style="margin-top: 30px;"><button class="logout-btn" onclick="logout()" style="width: 100%;">Logout</button></li>
        </ul>
    </div>

    <div class="main-content">
        <div class="header">
            <h1>🏔️ Khabar Darjeeling Ko Admin</h1>
            <div style="text-align: right;">
                <p id="adminName" style="margin: 0; color: #888; font-size: 13px;">Admin User</p>
                <p id="lastUpdate" style="margin: 5px 0 0; color: #555; font-size: 12px;">Syncing...</p>
            </div>
        </div>

        <div id="messageContainer"></div>

        <!-- Dashboard Tab -->
        <div id="dashboard" class="tab-content active">
            <h2>📊 Dashboard Overview</h2>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-number" id="totalSubmissions">0</div>
                    <div class="stat-label">Total Submissions</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number" id="pendingCount">0</div>
                    <div class="stat-label">Pending Review</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number" id="publishedCount">0</div>
                    <div class="stat-label">Published Articles</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number" id="rejectedCount">0</div>
                    <div class="stat-label">Rejected</div>
                </div>
            </div>
        </div>

        <!-- Submissions Tab -->
        <div id="submissions" class="tab-content">
            <h2>📬 News Submissions</h2>
            <div id="submissionsContainer" class="loading">
                <span class="spinner"></span>Loading submissions...
            </div>
        </div>

        <!-- Published Tab -->
        <div id="published" class="tab-content">
            <h2>📰 Published Articles</h2>
            <div id="publishedContainer" class="loading">
                <span class="spinner"></span>Loading articles...
            </div>
        </div>

        <!-- Settings Tab -->
        <div id="settings" class="tab-content">
            <h2>⚙️ Settings</h2>
            <div style="background: #181818; padding: 20px; border-radius: 8px; border: 1px solid #2a2a2a;">
                <h3>Admin Information</h3>
                <p>🔐 <strong>Email:</strong> <span id="adminEmail">Loading...</span></p>
                <p>🔑 <strong>Access Level:</strong> Full Admin</p>
                <hr style="border: none; border-top: 1px solid #2a2a2a; margin: 20px 0;">
                <h3>Database Status</h3>
                <p id="dbStatus">Checking...</p>
                <hr style="border: none; border-top: 1px solid #2a2a2a; margin: 20px 0;">
                <h3>Quick Actions</h3>
                <button class="btn btn-secondary" onclick="refreshData()" style="width: 100%; margin-bottom: 10px;">🔄 Refresh Data</button>
                <button class="btn btn-danger" onclick="logout()" style="width: 100%;">🚪 Logout</button>
            </div>
        </div>
    </div>
</div>

<!-- Approval Modal -->
<div id="approvalModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>✏️ Review Submission</h2>
            <button class="close-modal" onclick="closeModal('approvalModal')">✕</button>
        </div>
        
        <div id="submissionPreview"></div>

        <form id="approvalForm" style="margin-top: 20px;">
            <div class="form-group">
                <label>Status</label>
                <select id="approvalStatus">
                    <option value="published">✅ Publish</option>
                    <option value="rejected">❌ Reject</option>
                </select>
            </div>

            <div class="form-group" id="rejectionReasonGroup" style="display: none;">
                <label>Rejection Reason (optional)</label>
                <textarea id="rejectionReason" placeholder="Explain why this submission is being rejected..."></textarea>
            </div>

            <div class="form-group">
                <label>Author Name (can edit)</label>
                <input type="text" id="editAuthorName">
            </div>

            <div class="form-group">
                <label>Category (can edit)</label>
                <select id="editCategory">
                    <option value="Politics">Politics</option>
                    <option value="Tourism">Tourism</option>
                    <option value="Education">Education</option>
                    <option value="Sports">Sports</option>
                    <option value="Business">Business</option>
                    <option value="Tea">Tea Industry</option>
                    <option value="Weather">Weather</option>
                    <option value="Community">Community</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <div style="display: flex; gap: 10px;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">Save & Process</button>
                <button type="button" class="btn btn-secondary" onclick="closeModal('approvalModal')" style="flex: 1;">Cancel</button>
            </div>
        </form>
    </div>
</div>

<script type="module">
import { createClient } from 'https://esm.sh/@supabase/supabase-js';

const supabase = createClient(
    'https://zclotvuignhleyrvjekb.supabase.co',
    'sb_publishable_ccgt9ZOZR0kUJhdDwcLOpQ_or0_XjBK'
);

// Admin authentication
let currentAdmin = null;
let currentSubmissionId = null;

// Initialize
document.addEventListener('DOMContentLoaded', () => {
    // Check authentication - in production, implement proper auth
    const adminEmail = localStorage.getItem('adminEmail');
    if (!adminEmail) {
        window.location.href = '/admin/login.html';
        return;
    }

    document.getElementById('adminEmail').textContent = adminEmail;
    document.getElementById('adminName').textContent = adminEmail.split('@')[0];
    
    loadDashboardData();
    setupEventListeners();
    
    // Auto-refresh every 30 seconds
    setInterval(loadDashboardData, 30000);
});

// Setup event listeners
function setupEventListeners() {
    document.getElementById('approvalStatus').addEventListener('change', (e) => {
        const reasonGroup = document.getElementById('rejectionReasonGroup');
        reasonGroup.style.display = e.target.value === 'rejected' ? 'block' : 'none';
    });

    document.getElementById('approvalForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        await processSubmission();
    });
}

// Switch tabs
window.switchTab = function(tabName) {
    // Hide all tabs
    document.querySelectorAll('.tab-content').forEach(tab => {
        tab.classList.remove('active');
    });
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('active');
    });

    // Show selected tab
    document.getElementById(tabName).classList.add('active');
    event.target.classList.add('active');

    // Load tab-specific data
    if (tabName === 'submissions') {
        loadSubmissions();
    } else if (tabName === 'published') {
        loadPublished();
    }
};

// Load dashboard data
async function loadDashboardData() {
    try {
        const { data: submissions } = await supabase
            .from('news_submissions')
            .select('status');

        const { data: articles } = await supabase
            .from('news')
            .select('status');

        const totalSubmissions = submissions?.length || 0;
        const pendingCount = submissions?.filter(s => s.status === 'pending').length || 0;
        const publishedCount = articles?.filter(a => a.status === 'published').length || 0;
        const rejectedCount = submissions?.filter(s => s.status === 'rejected').length || 0;

        document.getElementById('totalSubmissions').textContent = totalSubmissions;
        document.getElementById('pendingCount').textContent = pendingCount;
        document.getElementById('publishedCount').textContent = publishedCount;
        document.getElementById('rejectedCount').textContent = rejectedCount;

        document.getElementById('lastUpdate').textContent = `Last updated: ${new Date().toLocaleTimeString()}`;
    } catch (err) {
        console.error('Error loading dashboard:', err);
    }
}

// Load submissions
async function loadSubmissions() {
    const container = document.getElementById('submissionsContainer');
    container.innerHTML = '<span class="spinner"></span>Loading submissions...';

    try {
        const { data, error } = await supabase
            .from('news_submissions')
            .select('*')
            .eq('status', 'pending')
            .order('created_at', { ascending: false });

        if (error) throw error;

        if (!data || data.length === 0) {
            container.innerHTML = '<div class="empty-state"><h3>✅ No pending submissions</h3><p>All submissions have been reviewed!</p></div>';
            return;
        }

        container.innerHTML = data.map(submission => `
            <div class="submission-item">
                <div class="submission-details">
                    <h3>${submission.title}</h3>
                    <span class="badge badge-pending">Pending</span>
                    <div class="submission-meta">
                        <span>✍️ ${submission.submitter_name}</span>
                        <span>📍 ${submission.location}</span>
                        <span>📂 ${submission.category}</span>
                        <span>📅 ${new Date(submission.created_at).toLocaleDateString()}</span>
                    </div>
                    <div class="submission-content">${submission.content.substring(0, 150)}...</div>
                </div>
                <div class="submission-actions">
                    <button class="btn btn-primary" onclick="openApprovalModal(${submission.id}, '${submission.title}', '${submission.submitter_name}', '${submission.category}', '${submission.content}')">Review</button>
                </div>
            </div>
        `).join('');
    } catch (err) {
        container.innerHTML = `<div class="error-message">Error loading submissions: ${err.message}</div>`;
    }
}

// Load published articles
async function loadPublished() {
    const container = document.getElementById('publishedContainer');
    container.innerHTML = '<span class="spinner"></span>Loading articles...';

    try {
        const { data, error } = await supabase
            .from('news')
            .select('*')
            .eq('status', 'published')
            .order('created_at', { ascending: false });

        if (error) throw error;

        if (!data || data.length === 0) {
            container.innerHTML = '<div class="empty-state"><h3>📭 No published articles</h3></div>';
            return;
        }

        container.innerHTML = data.map(article => `
            <div class="submission-item">
                <div class="submission-details">
                    <h3>${article.title}</h3>
                    <span class="badge badge-published">Published</span>
                    <div class="submission-meta">
                        <span>✍️ ${article.author_name}</span>
                        <span>📍 ${article.location}</span>
                        <span>📂 ${article.category}</span>
                        <span>📅 ${new Date(article.created_at).toLocaleDateString()}</span>
                    </div>
                </div>
                <div class="submission-actions">
                    <a href="/news/article.html?id=${article.id}" target="_blank" class="btn btn-secondary">View</a>
                    <button class="btn btn-danger" onclick="deleteArticle(${article.id})">Delete</button>
                </div>
            </div>
        `).join('');
    } catch (err) {
        container.innerHTML = `<div class="error-message">Error loading articles: ${err.message}</div>`;
    }
}

// Open approval modal
window.openApprovalModal = function(submissionId, title, author, category, content) {
    currentSubmissionId = submissionId;
    
    document.getElementById('submissionPreview').innerHTML = `
        <div style="background: #0f0f0f; padding: 15px; border-radius: 6px; margin-bottom: 20px;">
            <h3 style="margin-bottom: 10px;">${title}</h3>
            <p style="color: #888; margin-bottom: 10px;">
                <strong>${author}</strong> • ${category}
            </p>
            <p style="color: #aaa; line-height: 1.6; max-height: 200px; overflow-y: auto;">${content}</p>
        </div>
    `;

    document.getElementById('editAuthorName').value = author;
    document.getElementById('editCategory').value = category;
    document.getElementById('approvalStatus').value = 'published';
    document.getElementById('rejectionReasonGroup').style.display = 'none';

    document.getElementById('approvalModal').classList.add('active');
};

// Close modal
window.closeModal = function(modalId) {
    document.getElementById(modalId).classList.remove('active');
};

// Process submission (approve/reject)
async function processSubmission() {
    const status = document.getElementById('approvalStatus').value;
    const authorName = document.getElementById('editAuthorName').value;
    const category = document.getElementById('editCategory').value;

    try {
        if (status === 'published') {
            // Get submission details
            const { data: submission } = await supabase
                .from('news_submissions')
                .select('*')
                .eq('id', currentSubmissionId)
                .single();

            // Create published article
            const { error: insertError } = await supabase
                .from('news')
                .insert([{
                    title: submission.title,
                    content: submission.content,
                    category: category,
                    location: submission.location,
                    author_name: authorName,
                    status: 'published'
                }]);

            if (insertError) throw insertError;

            // Update submission status
            await supabase
                .from('news_submissions')
                .update({ status: 'published' })
                .eq('id', currentSubmissionId);

            showMessage('✅ Article published successfully!', 'success');
        } else {
            // Reject submission
            const rejectionReason = document.getElementById('rejectionReason').value;
            
            await supabase
                .from('news_submissions')
                .update({ status: 'rejected' })
                .eq('id', currentSubmissionId);

            showMessage('❌ Submission rejected', 'success');
        }

        closeModal('approvalModal');
        loadDashboardData();
        loadSubmissions();
    } catch (err) {
        showMessage(`Error: ${err.message}`, 'error');
    }
}

// Delete article
window.deleteArticle = async function(articleId) {
    if (!confirm('Are you sure you want to delete this article? This cannot be undone.')) return;

    try {
        await supabase
            .from('news')
            .delete()
            .eq('id', articleId);

        showMessage('✅ Article deleted', 'success');
        loadDashboardData();
        loadPublished();
    } catch (err) {
        showMessage(`Error: ${err.message}`, 'error');
    }
};

// Refresh data
window.refreshData = function() {
    loadDashboardData();
    showMessage('✅ Data refreshed', 'success');
};

// Show message
function showMessage(message, type) {
    const container = document.getElementById('messageContainer');
    container.innerHTML = `<div class="message ${type}-message">${message}</div>`;
    setTimeout(() => {
        container.innerHTML = '';
    }, 4000);
}

// Logout
window.logout = function() {
    localStorage.removeItem('adminEmail');
    window.location.href = '/admin/login.html';
};
</script>

</body>
</html>
