name:
 
Deploy
 
GitHub
 
Pages
 
(news)

on:

  
push:

    
branches:
 [
"main"
]
  
workflow_dispatch:

permissions:

  
contents:
 
read

  
pages:
 
write

  
id-token:
 
write

concurrency:

  
group:
 
"pages-news"

  
cancel-in-progress:
 
true

jobs:

  
build:

    
runs-on:
 
ubuntu-latest

    
steps:

      
-
 
name:
 
Upload
 
Pages
 
artifact

        
uses:
 
actions/upload-pages-artifact@v3

        
with:

          
path:
 
./news

  
deploy:

    
needs:
 
build

    
runs-on:
 
ubuntu-latest

    
steps:

      
-
 
name:
 
Deploy
 
to
 
GitHub
 
Pages

        
uses:
 
actions/deploy-pages@v4